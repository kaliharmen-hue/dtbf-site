---
import BaseLayout from "../layouts/BaseLayout.astro";
const withBase = (path = "") => `${import.meta.env.BASE_URL.replace(/\/$/, "")}/${path}`;
---

<BaseLayout title="Page not found | Dare to Break Free">
  <section class="page-hero">
    <p class="eyebrow">404</p>
    <h1>This page has let go of its old address.</h1>
    <p class="lede">Try the blog, the Share Your Story page, or head back home.</p>
    <div class="button-row">
      <a class="button" href={withBase()}>Home</a>
      <a class="button secondary" href={withBase("blog/")}>Blog</a>
    </div>
  </section>
</BaseLayout>
