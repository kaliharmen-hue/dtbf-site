---
import BaseLayout from "../layouts/BaseLayout.astro";

const formAction = "https://formspree.io/f/your-form-id";
---

<BaseLayout title="Contact | Dare to Break Free">
  <section class="page-hero">
    <p class="eyebrow">Contact</p>
    <h1>Get in touch</h1>
    <p class="lede">For story enquiries, book updates, newsletter notes, and thoughtful conversations around the work.</p>
  </section>

  <section class="form-section">
    <div>
      <p class="eyebrow">Message</p>
      <h2>Send a note</h2>
      <p>The site uses a form-first contact flow so the public email address does not have to sit exposed on every page.</p>
    </div>
    <form class="contact-form" action={formAction} method="POST">
      <label>
        Name
        <input name="name" type="text" autocomplete="name" required />
      </label>
      <label>
        Email
        <input name="email" type="email" autocomplete="email" required />
      </label>
      <label>
        Message
        <textarea name="message" rows="7" required></textarea>
      </label>
      <input type="hidden" name="form-name" value="contact" />
      <button class="button" type="submit">Send message</button>
    </form>
  </section>
</BaseLayout>
