---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="About | Dare to Break Free">
  <section class="page-hero">
    <p class="eyebrow">About</p>
    <h1>A place for honest stories about change.</h1>
    <p class="lede">Dare to Break Free is written from Southampton for readers navigating recovery, reinvention, and the slow work of becoming free.</p>
  </section>
  <section class="section two-column">
    <div>
      <p class="eyebrow">Author story</p>
      <h2>Raw, reflective, unsentimental</h2>
    </div>
    <p>This page is reserved for the author bio and a fuller account of the story behind the project. The voice should feel personal, direct, and grounded.</p>
  </section>
</BaseLayout>
